# IPAM Environment Configuration
#
# RECOMMENDED: Run init.sh (Linux/Mac) or init.ps1 (Windows) to
# auto-generate this file with secure random values.
#
# MANUAL: Copy this file to .env and replace all CHANGE_ME values:
#   cp .env.example .env

# ── Database ────────────────────────────────────────────────────
# Standard deployment uses the embedded PostgreSQL and Redis containers.
DB_USER=ipam_admin
DB_PASSWORD=CHANGE_ME
DB_NAME=ipam
REDIS_PASSWORD=CHANGE_ME

# Bring Your Own Database (BYOD):
# Uncomment and configure these if you are using an external database.
# If these are set, they will override the embedded database connection.
# EXTERNAL_DB_URL=postgresql+asyncpg://user:password@your-db-cluster:5432/ipam
# EXTERNAL_REDIS_URL=redis://:password@your-redis-cluster:6379/0
#
# Note: For local development without docker, set the DATABASE_URL environment variable:
# DATABASE_URL=postgresql+asyncpg://ipam_admin:CHANGE_ME@localhost:5432/ipam

# ── pgAdmin ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@ipam.local
PGADMIN_PASSWORD=CHANGE_ME

# ── SSO / OIDC ─────────────────────────────────────────────────────
# SSO is configured through the Setup Wizard UI or the System Settings
# API endpoint. The SSO admin group (for automatic RBAC role mapping)
# is stored in the database, not as an environment variable.

# ── CORS (comma-separated) ──────────────────────────────────────
# Defaults to EMPTY (no CORS) in production — the Nginx container
# proxies /api/ requests internally, so cross-origin access is not needed.
#
# For LOCAL DEVELOPMENT (Vite on port 5173 calling backend on 8000),
# uncomment the line below:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Debug Mode ──────────────────────────────────────────────────
# Only enable for local development — NEVER in production.
# DEBUG=true

# ── Application Secrets ─────────────────────────────────────────
# Generate cryptographically strong values before deploying:
#
#   JWT secret (64-char hex):
#     python -c "import secrets; print(secrets.token_hex(32))"
#
#   Fernet encryption key:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
#   Redis password:
#     python -c "import secrets; print(secrets.token_hex(16))"
#
JWT_SECRET_KEY=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME
