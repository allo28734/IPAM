# Copy this file to .env and fill in real values before deploying.
#
#   cp .env.example .env

# ── Database ────────────────────────────────────────────────────
# Standard deployment uses the embedded PostgreSQL and Redis containers.
DB_USER=ipam_admin
DB_PASSWORD=CHANGE_ME
DB_NAME=ipam
REDIS_PASSWORD=CHANGE_ME

# Bring Your Own Database (BYOD):
# Uncomment and configure these if you are using an external database.
# If these are set, they will override the embedded database connection.
# EXTERNAL_DB_URL=postgresql://user:password@your-db-cluster:5432/ipam
# EXTERNAL_REDIS_URL=redis://:password@your-redis-cluster:6379/0

# ── pgAdmin ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@ipam.local
PGADMIN_PASSWORD=CHANGE_ME

# ── CORS (comma-separated or JSON array) ────────────────────────
# Override the default localhost origins for production:
# CORS_ORIGINS=https://ipam.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Debug Mode ──────────────────────────────────────────────────
# Only enable for local development — NEVER in production.
# DEBUG=true

# ── Application Secrets ─────────────────────────────────────────
# Generate cryptographically strong values before deploying:
#
#   JWT secret (64-char hex):
#     python -c "import secrets; print(secrets.token_hex(32))"
#
#   Fernet encryption key:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
#   Redis password:
#     python -c "import secrets; print(secrets.token_hex(16))"
#
JWT_SECRET_KEY=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME
